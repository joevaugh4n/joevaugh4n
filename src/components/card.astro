---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<article class="py-2 px-4 shadow rounded border-yellow-200 border-2 w-fit">
  <!-- Title -->
  <h2>{title}</h2>
  <!-- Content. NB: this component is unopinionated about formatting and styling of its children -->
  <slot />
</article>
